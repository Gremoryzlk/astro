---
import site from '@data/site.json';

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      <!-- Бренд -->
      <div class="site-footer__brand">
        <a href="/" class="site-logo site-footer__logo">
          <div class="site-logo__mark">
            <svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" fill="rgba(255,255,255,.8)"/>
            </svg>
          </div>
          <div class="site-logo__text">
            <span class="site-logo__name">{site.company.name}</span>
            <span class="site-logo__tagline">{site.company.tagline}</span>
          </div>
        </a>
        <p class="site-footer__desc">
          Строим дома из газобетона, кирпича и керамических блоков в Ленинградской
          области с {site.company.foundedYear} года. Качество — наша гарантия.
        </p>
        <div class="site-footer__socials">
          {site.socials.telegram && (
            <a href={site.socials.telegram} class="site-footer__social" aria-label="Telegram" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="rgba(255,255,255,.7)">
                <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/>
              </svg>
            </a>
          )}
          {site.socials.vk && (
            <a href={site.socials.vk} class="site-footer__social" aria-label="ВКонтакте" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="rgba(255,255,255,.7)">
                <path d="M21.5 6.2c.1-.4 0-.7-.6-.7h-2c-.5 0-.7.3-.8.6 0 0-.9 2.2-2.2 3.6-.4.4-.6.6-.8.6-.1 0-.3-.2-.3-.6V6.2c0-.5-.1-.7-.6-.7H11c-.4 0-.6.3-.6.6 0 .6.9.7 1 2.3v3.5c0 .6-.1.7-.3.7-.6 0-2-2.2-2.9-4.8-.2-.5-.3-.7-.8-.7H5.4c-.5 0-.6.3-.6.6 0 .6.6 3.4 2.7 7.2 1.4 2.6 3.4 4 5.2 4 1.1 0 1.2-.2 1.2-.7v-1.8c0-.5.1-.6.5-.6.3 0 .7.1 1.8 1.1 1.2 1.2 1.4 1.8 2.1 1.8H20c.5 0 .8-.2.6-.7-.2-.5-.8-1.3-1.5-2.1-.4-.5-1-.9-1.2-1.2-.3-.3-.2-.5 0-.8.1-.1 2.2-3.1 2.4-4.2z"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Проекты -->
      <div>
        <div class="site-footer__col-title">Проекты</div>
        <ul class="site-footer__links">
          <li><a href="/projects/" class="site-footer__link">Все проекты</a></li>
          <li><a href="/projects/?floors=1" class="site-footer__link">Одноэтажные дома</a></li>
          <li><a href="/projects/?floors=2" class="site-footer__link">Двухэтажные дома</a></li>
          <li><a href="/compare/" class="site-footer__link">Сравнение проектов</a></li>
          <li><a href="/services/design/" class="site-footer__link">Индивидуальное проектирование</a></li>
        </ul>
      </div>

      <!-- Услуги -->
      <div>
        <div class="site-footer__col-title">Услуги</div>
        <ul class="site-footer__links">
          <li><a href="/services/design/"      class="site-footer__link">Проектирование</a></li>
          <li><a href="/services/foundation/"  class="site-footer__link">Фундамент под ключ</a></li>
          <li><a href="/services/roofing/"     class="site-footer__link">Монтаж кровли</a></li>
          <li><a href="/services/engineering/" class="site-footer__link">Инженерные сети</a></li>
          <li><a href="/services/finishing/"   class="site-footer__link">Отделка под ключ</a></li>
        </ul>
      </div>

      <!-- Контакты -->
      <div>
        <div class="site-footer__col-title">Контакты</div>
        <div class="site-footer__contact-item">
          <span class="site-footer__contact-label">Телефон</span>
          <span class="site-footer__contact-value">
            <a href={`tel:${site.company.phone}`}>{site.company.phoneFormatted}</a>
          </span>
        </div>
        <div class="site-footer__contact-item">
          <span class="site-footer__contact-label">E-mail</span>
          <span class="site-footer__contact-value">
            <a href={`mailto:${site.company.email}`}>{site.company.email}</a>
          </span>
        </div>
        <div class="site-footer__contact-item">
          <span class="site-footer__contact-label">Адрес</span>
          <span class="site-footer__contact-value" set:html={site.company.address.replace(', ', ',<br>')} />
        </div>
        <div class="site-footer__contact-item">
          <span class="site-footer__contact-label">Режим работы</span>
          <span class="site-footer__contact-value">{site.company.workingHours}</span>
        </div>
      </div>

    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;width:100%">
      <span>© {year} {site.company.legalName}. Все права защищены.</span>
      <div class="site-footer__bottom-links">
        <a href="/privacy/">Политика конфиденциальности</a>
        <a href="/terms/">Условия использования</a>
      </div>
    </div>
  </div>
</footer>
