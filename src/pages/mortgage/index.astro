---
import PageLayout from '@layouts/PageLayout.astro';
import site from '@data/site.json';

const BANKS = [
  { name: 'Сбербанк',   rate: 'от 8,5% годовых', desc: 'Загородная недвижимость · до 30 лет · от 15% взнос' },
  { name: 'ВТБ',        rate: 'от 8,8% годовых', desc: 'Строительство дома · до 25 лет · от 20% взнос' },
  { name: 'Альфа-банк', rate: 'от 9,2% годовых', desc: 'Частный дом · до 30 лет · от 10% взнос' },
] as const;

const PREFS = [
  { icon: '🏡', name: 'Сельская ипотека',  rate: 'от 0,1% годовых' },
  { icon: '👨‍👩‍👧', name: 'Семейная ипотека', rate: 'от 5,5% годовых' },
  { icon: '💻', name: 'IT-ипотека',        rate: 'от 5% годовых'   },
] as const;

const m = site.mortgage;
---

<PageLayout
  title="Ипотека на строительство"
  description="Рассчитайте ежемесячный платёж и узнайте условия ипотеки в ведущих банках."
>

  <div class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Финансирование</p>
      <h1 class="page-header__title">Ипотека на строительство</h1>
      <p class="page-header__subtitle">Рассчитайте ежемесячный платёж и узнайте условия в ведущих банках.</p>
    </div>
  </div>

  <section style="padding-block:var(--section-gap)">
    <div class="container">
      <div class="service-content__grid">

        <!-- Калькулятор + банки -->
        <div style="display:flex;flex-direction:column;gap:var(--space-10)">

          <!-- Калькулятор -->
          <div data-reveal>
            <h2 style="font-family:var(--ff-display);font-size:var(--fs-3xl);font-weight:300;letter-spacing:-0.02em;margin-bottom:var(--space-6)">
              Калькулятор ипотеки
            </h2>

            <div id="mortgageCalc" class="mortgage-section">
              <div class="mortgage-grid">
                <div class="form" style="gap:var(--space-5)">
                  <div class="form-field">
                    <label class="form-label" for="mortgagePrice">Стоимость дома, млн ₽</label>
                    <div class="form-input-wrap">
                      <input class="form-input" type="number" id="mortgagePrice" value={m.defaultHousePrice} min="1" max="100" step="0.5"/>
                      <span class="form-input-unit">млн</span>
                    </div>
                  </div>
                  <div class="form-field">
                    <label class="form-label" for="mortgageDown">
                      Первоначальный взнос, млн ₽
                      <span id="mortgageDownPct" style="color:var(--c-forest);font-weight:500">20%</span>
                    </label>
                    <div class="form-input-wrap">
                      <input class="form-input" type="number" id="mortgageDown" value={m.defaultDownPayment} min="0" step="0.1"/>
                      <span class="form-input-unit">млн</span>
                    </div>
                  </div>
                  <div class="form-field">
                    <label class="form-label" for="mortgageRate">Процентная ставка, % годовых</label>
                    <input class="form-input" type="number" id="mortgageRate" value={m.defaultRate} min="0.1" max="30" step="0.1"/>
                  </div>
                  <div class="form-field">
                    <label class="form-label" for="mortgageTerm">Срок ипотеки, лет</label>
                    <input class="form-input" type="number" id="mortgageTerm" value={m.defaultTermYears} min="1" max="30"/>
                  </div>
                  <button class="btn btn--accent btn--block btn--lg" data-modal-open="contactModal" type="button">
                    Оставить заявку на ипотеку
                  </button>
                  <p class="mortgage-disclaimer">
                    * Расчёт носит ориентировочный характер. Точные условия уточняйте у менеджера.
                  </p>
                </div>

                <div class="mortgage-result">
                  <div style="padding:var(--space-4);background:var(--c-forest);border-radius:var(--radius-sm);margin-bottom:var(--space-4)">
                    <p style="font-size:var(--fs-xs);font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:4px">Ежемесячный платёж</p>
                    <p id="mortgageMonthly" style="font-family:var(--ff-display);font-size:var(--fs-3xl);font-weight:300;color:var(--c-white);letter-spacing:-0.02em;line-height:1">—</p>
                  </div>
                  <div class="mortgage-result__item">
                    <span class="mortgage-result__label">Сумма кредита</span>
                    <span class="mortgage-result__value" id="mortgageLoan">—</span>
                  </div>
                  <div class="mortgage-result__item">
                    <span class="mortgage-result__label">Первоначальный взнос</span>
                    <span class="mortgage-result__value" id="mortgageDownAmt">—</span>
                  </div>
                  <div class="mortgage-result__item">
                    <span class="mortgage-result__label">Общая сумма выплат</span>
                    <span class="mortgage-result__value" id="mortgageTotalPay">—</span>
                  </div>
                  <div class="mortgage-result__item">
                    <span class="mortgage-result__label">Переплата</span>
                    <span class="mortgage-result__value" id="mortgageOverpay">—</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Банки-партнёры -->
          <div data-reveal>
            <h2 style="font-family:var(--ff-display);font-size:var(--fs-2xl);font-weight:300;letter-spacing:-0.02em;margin-bottom:var(--space-6)">
              Ипотека от банков-партнёров
            </h2>

            <div style="display:flex;flex-direction:column;gap:var(--space-4)">
              {BANKS.map(bank => (
                <div class="bank-card">
                  <div style="font-family:var(--ff-display);font-size:var(--fs-2xl);font-weight:300;color:var(--c-forest)">{bank.name}</div>
                  <div>
                    <p style="font-size:var(--fs-base);font-weight:500;color:var(--c-text)">{bank.rate}</p>
                    <p style="font-size:var(--fs-sm);color:var(--c-text-60)">{bank.desc}</p>
                  </div>
                  <button class="btn btn--primary btn--sm" data-modal-open="contactModal" type="button">Подать заявку</button>
                </div>
              ))}

              <div class="bank-card bank-card--dark">
                <div>
                  <p style="font-size:var(--fs-base);font-weight:500;color:var(--c-white)">Льготная ипотека · от 2%</p>
                  <p style="font-size:var(--fs-sm);color:rgba(255,255,255,.65)">Сельская ипотека, семейная, IT-ипотека — проконсультируем по условиям.</p>
                </div>
                <button class="btn btn--accent btn--sm" data-modal-open="contactModal" type="button">Узнать подробнее</button>
              </div>
            </div>
          </div>

        </div>

        <!-- Сайдбар -->
        <aside class="sticky-sidebar">
          <div class="sidebar-cta-card">
            <h3 class="sidebar-cta-card__title">Поможем одобрить ипотеку</h3>
            <p class="sidebar-cta-card__text">Подберём банк с лучшими условиями и сопроводим сделку бесплатно.</p>
            <button class="btn btn--accent btn--block" data-modal-open="contactModal" type="button">Получить помощь</button>
          </div>

          <div style="background:var(--c-sand);border-radius:var(--radius-md);padding:var(--space-5)">
            <p style="font-size:var(--fs-xs);font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--c-text-60);margin-bottom:var(--space-4)">
              Льготные программы
            </p>
            <div style="display:flex;flex-direction:column;gap:var(--space-3)">
              {PREFS.map(p => (
                <div style="display:flex;align-items:center;gap:var(--space-3);padding:var(--space-3);background:var(--c-white);border-radius:var(--radius-sm)">
                  <span style="font-size:1.2rem" aria-hidden="true">{p.icon}</span>
                  <div>
                    <p style="font-size:var(--fs-sm);font-weight:500;color:var(--c-text)">{p.name}</p>
                    <p style="font-size:var(--fs-xs);color:var(--c-text-60)">{p.rate}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

</PageLayout>

<style is:global>
  .bank-card {
    background: var(--c-white);
    border: 1px solid var(--c-stone);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: var(--space-4);
    align-items: center;
  }
  .bank-card--dark {
    background: linear-gradient(135deg, #0F3D2E, #1a5240);
    border: none;
    grid-template-columns: 1fr auto;
  }
  @media (max-width: 600px) {
    .bank-card { grid-template-columns: 1fr; }
    .bank-card--dark { grid-template-columns: 1fr; }
    .bank-card .btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  import '@scripts/calculators.ts';
</script>
