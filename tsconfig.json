{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":         ["./src/*"],
      "@data/*":     ["./src/data/*"],
      "@lib/*":      ["./src/lib/*"],
      "@components/*": ["./src/components/*"],
      "@scripts/*":  ["./src/scripts/*"],
      "@styles/*":   ["./src/styles/*"],
      "@layouts/*":  ["./src/layouts/*"]
    },
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*.ts", "src/**/*.astro"]
}
